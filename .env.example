# AIS Maritime Pipeline - Environment Configuration
# Copy this file to .env and adjust values for your environment

# Spark
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DB=ais_analytics
PG_USER=postgres
PG_PASSWORD=changeme

# AWS S3 (for cloud deployment)
S3_BUCKET=ais-maritime-data
S3_REGION=us-east-1

# Data
DATA_BASE_DIR=./data
BATCH_SIZE=500000
